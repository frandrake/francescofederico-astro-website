---
import Icon from './Icon.astro';
---

<aside>
	<h2>Get in touch</h2>
	<div class="contact-actions">
		<a href="https://www.linkedin.com/in/federicofrancesco/" target="_blank" rel="noreferrer" class="contact-link">
			Connect on LinkedIn
			<Icon icon="arrow-right" size="1.2em" />
		</a>
		<a href="mailto:francesco@francescofederico.net" class="contact-link contact-link--secondary">
			Email Francesco
			<Icon icon="paper-plane-tilt" size="1.2em" />
		</a>
	</div>
</aside>

<style>
	aside {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
		border-top: 1px solid var(--gray-800);
		border-bottom: 1px solid var(--gray-800);
		padding: 5rem 1.5rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	h2 {
		font-size: var(--text-xl);
		text-align: center;
		color: var(--gray-0);
	}

	.contact-actions {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
	}

	.contact-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.75rem 1.5rem;
		border-radius: 0.75rem;
		text-decoration: none;
		font-weight: 600;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		box-shadow: var(--shadow-sm);
		transition: background var(--theme-transition);
	}

	.contact-link:hover {
		background: var(--accent-dark);
	}

	.contact-link--secondary {
		background: transparent;
		color: var(--gray-200);
		border: 1px solid var(--gray-800);
		box-shadow: none;
	}

	.contact-link--secondary:hover {
		background: transparent;
		color: var(--gray-0);
		border-color: var(--gray-700);
	}

	@media (min-width: 50em) {
		aside {
			padding: 5rem 7.5rem;
			flex-direction: row;
			justify-content: space-between;
		}

		h2 {
			font-size: var(--text-3xl);
			text-align: left;
		}

		.contact-actions {
			flex-direction: row;
		}
	}
</style>
