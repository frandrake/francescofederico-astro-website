---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Chronicles of Change — AI & Marketing Leadership Newsletter"
	description="A newsletter exploring how AI is reshaping marketing leadership, the CMO mandate, and organisational design. By Francesco Federico."
	image="/assets/coc-logo.png"
>
	<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "Periodical",
			"name": "Chronicles of Change",
			"alternateName": "Chronicles of Change by Francesco Federico",
			"author": {
				"@type": "Person",
				"name": "Francesco Federico",
				"jobTitle": "Chief Marketing Officer",
				"worksFor": {"@type": "Organization", "name": "S&P Global"}
			},
			"description": "Chronicles of Change is a newsletter by Francesco Federico, CMO of S&P Global, providing evidence-first analysis on how AI is reshaping marketing leadership, the CMO mandate, and organisational design. Published on Substack and LinkedIn with over 100 issues.",
			"url": "https://chroniclesofchange.substack.com",
			"image": "https://francescofederico.com/assets/coc-logo.png",
			"inLanguage": "en",
			"about": ["AI Marketing", "Marketing Leadership", "CMO Strategy", "Organisational Design", "Hybrid Intelligence"]
		}
	</script>
	<div class="stack gap-20">
		<main class="wrapper stack gap-12">
			<!-- Answer capsule for AI extraction -->
			<div class="answer-capsule" role="doc-abstract">
				<p>Chronicles of Change is a newsletter by Francesco Federico, Chief Marketing Officer of S&P Global. It provides evidence-first analysis on how AI is reshaping marketing leadership, the CMO mandate, and organisational design. Published on Substack and LinkedIn since 2023, with over 100 issues. The editorial lens is operator-led, written for senior marketing leaders who need rigorous frameworks and commercially grounded insights rather than hype cycles. Topics include agentic AI, hybrid intelligence, marketing transformation, and enterprise operating models.</p>
			</div>

			<Hero title="Chronicles of Change" tagline="Evidence-first analysis for marketing leaders in the age of AI." align="start">
				<img src="/assets/coc-logo.png" alt="Chronicles of Change logo" width="240" height="240" />
			</Hero>

			<section class="stack gap-4 content">
				<p>
					<em>Chronicles of Change</em> explores how AI is reshaping the CMO mandate, marketing leadership, and organisational design. Each issue focuses on practical strategic decisions: where autonomy belongs, which capabilities to centralise, and how to move from isolated pilots to repeatable operating models.
				</p>
				<p>
					The editorial lens is evidence-first and operator-led. I write for senior leaders who need clear thinking, rigorous frameworks, and commercially grounded action — not hype cycles. New editions are published regularly on both Substack and LinkedIn.
				</p>
				<div class="actions">
					<a href="https://chroniclesofchange.substack.com" target="_blank" rel="noreferrer">Read on Substack</a>
					<a href="https://www.linkedin.com/newsletters/7062450977085255682/" target="_blank" rel="noreferrer">Follow on LinkedIn</a>
				</div>
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.answer-capsule {
		max-width: 65ch;
		margin: 0 auto;
		padding: 0.75rem 1.5rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		line-height: 1.6;
	}

	img {
		border-radius: 1rem;
		box-shadow: var(--shadow-md);
	}

	.content {
		max-width: 75ch;
	}

	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.actions a {
		display: inline-block;
		padding: 0.75rem 1.1rem;
		border-radius: 0.75rem;
		text-decoration: none;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-700);
	}
</style>
