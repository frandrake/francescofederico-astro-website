---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Francesco Federico — Global CMO, Author, Speaker"
	description="Francesco Federico is Global CMO at S&P Global, author of The Agentic CMO, and publisher of Chronicles of Change."
	image="/assets/portrait.jpg"
>
	<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Francesco Federico",
			"url": "https://francescofederico.com",
			"image": "https://francescofederico.com/assets/portrait.jpg",
			"jobTitle": "Chief Marketing Officer",
			"worksFor": {
				"@type": "Organization",
				"name": "S&P Global"
			},
			"sameAs": [
				"https://www.linkedin.com/in/federicofrancesco/",
				"https://chroniclesofchange.substack.com"
			],
			"description": "Global CMO at S&P Global, author of The Agentic CMO, publisher of Chronicles of Change.",
			"knowsLanguage": ["en", "it"]
		}
	</script>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Francesco Federico"
					tagline="Global CMO. Author of The Agentic CMO. Building hybrid intelligence at the intersection of marketing and AI."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="book" size="1.33em" /> Author</Pill>
						<Pill><Icon icon="microphone-stage" size="1.33em" /> Speaker</Pill>
						<Pill><Icon icon="pencil-line" size="1.33em" /> Writer</Pill>
						<Pill><Icon icon="strategy" size="1.33em" /> CMO</Pill>
					</div>
				</Hero>

				<img
					alt="Portrait of Francesco Federico"
					width="480"
					height="620"
					src="/assets/portrait.jpg"
				/>
			</header>

			<Skills />

			<section class="quick-links">
				<a href="/about/" class="card">
					<h3>About Francesco</h3>
					<p>Career history, awards, advisory roles, and speaking profile.</p>
				</a>
				<a href="/book/" class="card">
					<h3>The Agentic CMO</h3>
					<p>A practical playbook for building hybrid intelligence marketing teams.</p>
				</a>
				<a href="/newsletter/" class="card">
					<h3>Chronicles of Change</h3>
					<p>Evidence-first analysis on the future of marketing leadership.</p>
				</a>
			</section>
		</div>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	.quick-links {
		display: grid;
		gap: 1rem;
	}

	.card {
		display: block;
		padding: 1.25rem;
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		text-decoration: none;
		color: inherit;
		background: var(--gradient-subtle);
	}

	.card h3 {
		margin-bottom: 0.5rem;
		font-size: var(--text-lg);
	}

	.card p {
		color: var(--gray-300);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}

		.quick-links {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
