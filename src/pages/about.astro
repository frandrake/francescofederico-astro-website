---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="About Francesco Federico — Career, Awards & Speaking"
	description="Global CMO at S&P Global. Two decades of marketing leadership across Vodafone, Acer, JLL. Author of The Agentic CMO. Fellow of CIM."
	image="/assets/portrait.jpg"
>
	<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Francesco Federico",
			"givenName": "Francesco",
			"familyName": "Federico",
			"url": "https://francescofederico.com/about/",
			"image": "https://francescofederico.com/assets/portrait.jpg",
			"jobTitle": "Chief Marketing Officer",
			"worksFor": {"@type": "Organization", "name": "S&P Global", "url": "https://www.spglobal.com"},
			"alumniOf": [
				{"@type": "EducationalOrganization", "name": "Università Cattolica del Sacro Cuore"},
				{"@type": "EducationalOrganization", "name": "INSEAD"},
				{"@type": "EducationalOrganization", "name": "Harvard University"},
				{"@type": "EducationalOrganization", "name": "IMD Business School"},
				{"@type": "EducationalOrganization", "name": "IE Business School"}
			],
			"hasOccupation": [
				{"@type": "Role", "roleName": "Chief Marketing Officer", "startDate": "2025-01", "memberOf": {"@type": "Organization", "name": "S&P Global"}},
				{"@type": "Role", "roleName": "Managing Director, Global Head of Marketing, Ratings", "startDate": "2023-11", "endDate": "2025-01", "memberOf": {"@type": "Organization", "name": "S&P Global"}},
				{"@type": "Role", "roleName": "Executive Director, Global Marketing Technology", "memberOf": {"@type": "Organization", "name": "JLL"}},
				{"@type": "Role", "roleName": "Global Digital Marketing Lead", "memberOf": {"@type": "Organization", "name": "Acer"}},
				{"@type": "Role", "roleName": "Digital Marketing Manager", "memberOf": {"@type": "Organization", "name": "Vodafone"}}
			],
			"award": ["CMO to Watch 2025", "Vodafone Online Innovation Award", "Digital Experience Awards Winner", "Fellow of the Chartered Institute of Marketing (FCIM)"],
			"sameAs": ["https://www.linkedin.com/in/federicofrancesco/", "https://chroniclesofchange.substack.com"],
			"description": "Francesco Federico is the Chief Marketing Officer of S&P Global. Previously CMO at JLL, and senior marketing leader at Acer and Vodafone. Author of The Agentic CMO. Fellow of the Chartered Institute of Marketing."
		}
	</script>
	<div class="stack gap-20">
		<main class="wrapper about">
			<!-- Answer capsule for AI extraction -->
			<div class="answer-capsule" role="doc-abstract">
				<p>Francesco Federico is the Chief Marketing Officer (CMO) of S&P Global, a Fortune 500 financial data and analytics company. He joined S&P Global in November 2023 as Managing Director, Global Head of Marketing for Ratings, and became CMO in January 2025. He previously served as Executive Director of Global Marketing Technology at JLL, led global digital marketing at Acer, and held digital marketing roles at Vodafone. He is the author of The Agentic CMO (2025) and publisher of Chronicles of Change newsletter. He holds a JD in Law from Università Cattolica and is a Fellow of the Chartered Institute of Marketing (FCIM). He is a member of the World Economic Forum Strategic Communicators Exchange and serves as Non-Executive Director on two boards.</p>
			</div>

			<Hero
				title="About Francesco"
				tagline="Global CMO. Operator at the intersection of technology, data, and marketing leadership."
				align="start"
			>
				<img width="480" height="620" src="/assets/portrait.jpg" alt="Francesco Federico portrait" />
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content stack gap-4">
					<p>
						I started in Milan with a JD in Law at Università Cattolica, then moved early into building companies where technology and commercial growth met directly. In those startup years I founded Shreppy, which was acquired by Telecom Italia, and launched ventures including TripShake and Digital Natives to test digital demand models in real markets, not in slideware.
					</p>
					<p>
						At Vodafone, across Milan and London, I led the launch of the first My Vodafone app and scaled adoption to 90%, with rollout across nine European markets. That period shaped my operating belief: product, channel, and data only create advantage when leadership teams align around measurable behaviour change.
					</p>
					<p>
						At Acer in Lugano and Taipei, I led global digital marketing, driving a 35% increase in online sales and introducing real-time pricing logic that delivered 25% revenue uplift while reducing costs by 10%. I then spent seven years at JLL in London and globally, moving from EMEA Digital Marketing Director to Executive Director of Global Marketing Technology, building teams from scratch across regions and using hybrid intelligence systems that supported billions in real estate transactions via the JLL Investor Center.
					</p>
					<p>
						I joined S&amp;P Global in 2023 as Managing Director, Global Head of Marketing for Ratings, and became Chief Marketing Officer in January 2025. The through-line has stayed constant — evidence first, strong governance, and hybrid intelligence organisations where human judgement and agentic systems are orchestrated with clear accountability.
					</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Career Highlights</h2>
				<ul class="content highlights">
					<li>Chief Marketing Officer, S&amp;P Global (Jan 2025–present), following MD/Global Head of Marketing, Ratings (Nov 2023–Jan 2025).</li>
					<li>Built and scaled marketing teams at JLL from the ground up — 30+ across EMEA and 50+ globally.</li>
					<li>Delivered +50% conversion year on year at JLL, including +60% through conversational AI programmes.</li>
					<li>Enabled billions in transaction value via the JLL Investor Center digital ecosystem.</li>
					<li>At Acer, drove +35% online sales and deployed dynamic pricing systems (+25% revenue, -10% costs).</li>
					<li>At Vodafone, launched the first My Vodafone app to 90% adoption across nine markets.</li>
				</ul>
			</section>

			<section>
				<h2 class="section-title">Awards &amp; Recognition</h2>
				<ul class="content highlights">
					<li>CMO to Watch 2025</li>
					<li>Vodafone Online Innovation Award</li>
					<li>Digital Experience Awards Winner</li>
					<li>Fellow of the Chartered Institute of Marketing (FCIM)</li>
				</ul>
			</section>

			<section>
				<h2 class="section-title">Board &amp; Advisory Roles</h2>
				<ul class="content highlights">
					<li>World Economic Forum Strategic Communicators Exchange (2025–present)</li>
					<li>Diocese of Westminster Academy Trust — Non-Executive Director</li>
					<li>St Martins of Tours Housing Association — Non-Executive Director</li>
					<li>HFS Research Advisory Board</li>
					<li>IDC Advisory Board</li>
					<li>Henry Stewart Publications Editorial Board</li>
				</ul>
			</section>

			<section>
				<h2 class="section-title">Media &amp; Speaking</h2>
				<div class="content">
					<p>
						Francesco speaks at global events on agentic AI, marketing transformation, and leadership operating models for hybrid intelligence teams. For media and speaking enquiries: <a href="mailto:francesco@francescofederico.net">francesco@francescofederico.net</a>.
					</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Education</h2>
				<ul class="content highlights">
					<li>JD Law, Università Cattolica</li>
					<li>INSEAD International Directors Programme (2026–2027)</li>
					<li>Harvard CS50 for Business Professionals</li>
					<li>IMD Digital Transformation Programme</li>
					<li>IE Innovation for Growth</li>
				</ul>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.answer-capsule {
		max-width: 65ch;
		margin: 0 auto;
		padding: 0.75rem 1.5rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		line-height: 1.6;
	}

	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.highlights {
		display: grid;
		gap: 0.65rem;
		padding-left: 1.25rem;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
